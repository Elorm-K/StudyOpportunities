# Copy to .env (gitignored) for local dev. On Railway, set these in the service Variables tab.

# Anthropic auth — required. Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Operator approval gate (server/config.py). If unset, operator endpoints are disabled.
OPERATOR_TOKEN=

# Optional overrides (defaults live in server/config.py)
# CLAUDE_MODEL=claude-opus-4-8
# APPROVAL_REQUIRED=true
# MAX_BUDGET_USD_INTAKE=1.50
# MAX_BUDGET_USD_RESEARCH=12.0
# MAX_TURNS=300
# AGENT_DIR=
